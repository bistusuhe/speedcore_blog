    "class-variance-authority": "0.7.1",
    "tailwindcss-animate": "1.0.7",
    "@giscus/react": "3.1.0",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-tooltip": "1.1.6",
    "reading-time": "1.5.0",
    "glob": "11.0.0",
    "date-fns": "4.1.0",
    "nanoid": "5.0.9"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "@types/node": "22.10.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "tailwindcss": "3.4.17",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20",
    "@tailwindcss/typography": "0.5.15",
    "eslint": "9.18.0",
    "eslint-config-next": "15.1.6",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "@types/katex": "0.16.7",
    "@types/mdx": "2.0.13"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.3"
}
