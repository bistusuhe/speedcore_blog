    "next-themes": "0.4.4",
    "framer-motion": "11.18.0",
    "next-mdx-remote": "5.0.0",
    "gray-matter": "4.0.3",
    "rehype-pretty-code": "0.14.0",
    "shiki": "1.24.4",
    "rehype-slug": "6.0.0",
    "rehype-autolink-headings": "7.1.0",
    "remark-gfm": "4.0.0",
    "remark-math": "6.0.0",
    "rehype-katex": "7.0.1",
    "katex": "0.16.11",
    "rehype-raw": "7.0.0",
    "fuse.js": "7.0.0",
    "mermaid": "11.4.1",
    "lucide-react": "0.469.0",
