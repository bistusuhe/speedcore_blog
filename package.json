{
  "name": "suhe-blog",
  "version": "1.0.0",
  "private": true,
  "description": "speedcore（Su He）个人技术博客 + 项目展示网站",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
